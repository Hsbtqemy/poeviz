# Variables d'environnement du service poeviz.
# Copier en `/srv/poeviz/.env` puis ajuster. Lu par systemd (EnvironmentFile) et par
# `python -m backend.main`. Format strict : KEY=value (pas de guillemets, pas d'espaces
# autour du =).

# Hôte/port d'écoute. Derrière nginx, on reste sur la boucle locale : seul nginx parle
# au service, jamais l'extérieur en direct.
HOST=127.0.0.1
PORT=8000

# Origines autorisées pour le CORS (séparées par des virgules). En production :
# l'origine publique du site. En local on peut laisser "*".
ALLOWED_ORIGINS=https://poeviz.edito-revue.fr
